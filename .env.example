# ---------------------------------------------------------------------------
# FiberPayKit environment configuration
# Copy this file to `.env` in the repo root (used by docker-compose + apps).
# ---------------------------------------------------------------------------

# Database (PostgreSQL used by docker-compose + Prisma).
DATABASE_URL="postgresql://fiberpaykit:fiberpaykit@localhost:5432/fiberpaykit"

# Redis (BullMQ webhook + polling queues).
REDIS_URL="redis://localhost:6379"

# API server.
API_PORT=4000
API_URL="http://localhost:4000"

# Web (Next.js dashboard + hosted checkout).
WEB_URL="http://localhost:3000"

# Fiber integration mode: "mock" (default demo) or "fiber-rpc" (real node).
FIBER_MODE="mock"
FIBER_RPC_URL="http://127.0.0.1:8227"
FIBER_RPC_TIMEOUT_MS=10000

# Optional Fiber invoice features (only used in fiber-rpc mode).
FIBER_FALLBACK_ADDRESS=""
FIBER_ALLOW_MPP="false"
FIBER_ALLOW_TRAMPOLINE_ROUTING="false"

# Webhook delivery.
WEBHOOK_MAX_ATTEMPTS=5

# Invoice status polling interval (ms). 5000 in dev, 15000-30000 in prod.
INVOICE_POLL_INTERVAL_MS=5000

# Secrets (DEV ONLY — replace in production).
JWT_SECRET="dev_only"
ENCRYPTION_KEY="dev_only_32_byte_key_0000000000000"

# CORS allow-list (comma separated). Defaults to WEB_URL when empty.
CORS_ORIGINS=""

# ---------------------------------------------------------------------------
# Web-only public vars (safe to expose to the browser).
# NEVER put FIBER_RPC_URL or secrets behind NEXT_PUBLIC_*.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
# Demo dashboard uses the seeded demo merchant API key (demo only).
NEXT_PUBLIC_DEMO_API_KEY="fpk_test_demo"
