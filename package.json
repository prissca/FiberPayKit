{
  "name": "fiberpaykit",
  "version": "0.1.0",
  "private": true,
  "description": "FiberPayKit — reusable Fiber Network merchant checkout, webhook relay, and multi-asset payment infrastructure.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "pnpm --filter @fiberpaykit/shared build && pnpm --filter @fiberpaykit/sdk build && pnpm --filter @fiberpaykit/api build && pnpm --filter @fiberpaykit/web build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @fiberpaykit/api db:migrate",
    "db:push": "pnpm --filter @fiberpaykit/api db:push",
    "db:generate": "pnpm --filter @fiberpaykit/api db:generate",
    "db:seed": "pnpm --filter @fiberpaykit/api db:seed",
    "db:reset": "pnpm --filter @fiberpaykit/api db:reset",
    "dev:api": "pnpm --filter @fiberpaykit/api dev",
    "dev:web": "pnpm --filter @fiberpaykit/web dev"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "msgpackr-extract"
    ]
  }
}
